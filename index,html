<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kopi Senja | Professional POS System</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;700;800&display=swap');
        body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: #f3f4f6; }
        .tab-content { display: none; }
        .tab-content.active { display: block; }
        .glass-nav { background: rgba(10, 10, 10, 0.8); backdrop-blur: 15px; }
        .custom-scroll::-webkit-scrollbar { width: 4px; }
        .custom-scroll::-webkit-scrollbar-thumb { background: #d1d5db; border-radius: 10px; }
    </style>
</head>
<body class="text-stone-900">

    <div class="fixed bottom-6 left-1/2 -translate-x-1/2 z-[100] flex gap-2 bg-stone-900/90 p-2 rounded-2xl shadow-2xl border border-white/10 no-print">
        <button onclick="switchTab('customer')" class="flex items-center gap-2 px-5 py-2.5 rounded-xl text-xs font-bold text-white hover:bg-white/10 transition"><i class="fas fa-user"></i> Customer</button>
        <button onclick="switchTab('admin')" class="flex items-center gap-2 px-5 py-2.5 rounded-xl text-xs font-bold text-orange-400 hover:bg-white/10 transition"><i class="fas fa-chart-line"></i> Admin Dashboard</button>
    </div>

    <div id="customer" class="tab-content active no-print">
        <nav class="glass-nav text-white p-4 sticky top-0 z-50 flex justify-between items-center px-6 lg:px-12 border-b border-white/10">
            <h1 class="text-xl font-black tracking-tighter text-orange-500 italic">KOPI<span class="text-white font-normal">SENJA.</span></h1>
            <div class="flex items-center gap-6">
                <button onclick="showHistory()" class="text-xs font-bold uppercase tracking-widest hover:text-orange-500">History</button>
                <div class="h-8 w-[1px] bg-white/20"></div>
                <div class="relative">
                    <i class="fas fa-shopping-cart text-xl"></i>
                    <span id="cart-count" class="absolute -top-3 -right-3 bg-orange-600 text-white text-[10px] rounded-full h-5 w-5 flex items-center justify-center font-black">0</span>
                </div>
            </div>
        </nav>

        <main class="container mx-auto px-4 py-8 flex flex-col lg:flex-row gap-8">
            <div class="flex-1">
                <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-10">
                    <div>
                        <h2 class="text-3xl font-extrabold tracking-tight">Cari Inspirasimu ☕</h2>
                        <p class="text-stone-500 text-sm">Pilih meja dan mulai pesan menu favorit.</p>
                    </div>
                    <div class="flex gap-2">
                        <input type="text" id="search-input" onkeyup="filterMenu()" placeholder="Cari kopi..." class="px-4 py-2.5 rounded-xl border border-stone-200 text-sm focus:ring-2 focus:ring-orange-500 outline-none w-full md:w-64">
                    </div>
                </div>

                <div class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-4 gap-4" id="menu-grid"></div>
            </div>

            <aside class="lg:w-96 bg-white rounded-[2.5rem] shadow-2xl p-8 h-fit sticky top-24 border border-stone-100">
                <h3 class="text-xl font-bold mb-6">Detail Pesanan</h3>
                
                <div class="mb-6">
                    <label class="text-[10px] font-black text-stone-400 uppercase tracking-widest mb-2 block">Nomor Meja</label>
                    <select id="table-select" class="w-full p-3 rounded-xl border border-stone-100 bg-stone-50 font-bold text-sm focus:border-orange-500 outline-none">
                        <option value="1">Meja 01 (Indoor)</option>
                        <option value="2">Meja 02 (Indoor)</option>
                        <option value="3">Meja 03 (Outdoor)</option>
                        <option value="T-01">Take Away</option>
                    </select>
                </div>

                <div id="cart-items" class="space-y-4 mb-8 max-h-[300px] overflow-y-auto custom-scroll pr-2"></div>

                <div class="space-y-3 pt-6 border-t border-stone-50">
                    <div class="flex justify-between text-xs font-bold text-stone-400">
                        <span>Subtotal</span>
                        <span id="subtotal">Rp 0</span>
                    </div>
                    <div class="flex justify-between text-2xl font-black text-stone-900">
                        <span>Total</span>
                        <span id="grand-total" class="text-orange-600">Rp 0</span>
                    </div>

                    <div class="pt-4 space-y-2">
                        <label class="text-[10px] font-black text-stone-400 uppercase tracking-widest block">Metode Pembayaran</label>
                        <div class="flex gap-2">
                            <button onclick="setPayment('Cash')" id="pay-cash" class="flex-1 py-3 rounded-xl border-2 border-stone-100 text-[10px] font-bold transition-all active-pay border-orange-500 bg-orange-50">CASH</button>
                            <button onclick="setPayment('QRIS')" id="pay-qris" class="flex-1 py-3 rounded-xl border-2 border-stone-100 text-[10px] font-bold transition-all">QRIS</button>
                        </div>
                    </div>

                    <button onclick="processOrder()" class="w-full bg-stone-950 text-white font-bold py-5 rounded-2xl mt-4 hover:bg-orange-600 transition-all shadow-xl shadow-orange-900/10 uppercase tracking-widest text-xs">Konfirmasi & Pesan</button>
                </div>
            </aside>
        </main>
    </div>

    <div id="admin" class="tab-content no-print bg-stone-50 min-h-screen">
        <div class="flex">
            <aside class="w-20 lg:w-64 bg-stone-950 min-h-screen p-6 text-white hidden md:block">
                <h2 class="text-xl font-black text-orange-500 mb-10 hidden lg:block italic tracking-tighter text-center">ADMIN PANEL</h2>
                <nav class="space-y-2">
                    <div class="p-4 bg-orange-600 rounded-2xl text-center"><i class="fas fa-home"></i> <span class="hidden lg:inline ml-2 font-bold">Dashboard</span></div>
                    <div class="p-4 hover:bg-white/5 rounded-2xl text-center transition cursor-pointer"><i class="fas fa-boxes"></i> <span class="hidden lg:inline ml-2 font-bold">Stok Menu</span></div>
                </nav>
            </aside>

            <main class="flex-1 p-6 lg:p-10">
                <header class="flex justify-between items-center mb-10">
                    <h1 class="text-3xl font-black tracking-tight">Dashboard Overview</h1>
                    <div class="bg-white px-6 py-3 rounded-2xl shadow-sm flex items-center gap-4">
                        <div class="text-right">
                            <p class="text-[10px] font-bold text-stone-400 uppercase tracking-widest">Revenue Hari Ini</p>
                            <h4 id="admin-revenue" class="text-xl font-black text-stone-900">Rp 0</h4>
                        </div>
                    </div>
                </header>

                <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-10">
                    <div class="bg-white p-6 rounded-[2rem] shadow-sm">
                        <p class="text-[10px] font-black text-stone-400 uppercase tracking-widest mb-1">Menunggu</p>
                        <h3 id="stat-pending" class="text-3xl font-black">0</h3>
                    </div>
                    <div class="bg-white p-6 rounded-[2rem] shadow-sm">
                        <p class="text-[10px] font-black text-stone-400 uppercase tracking-widest mb-1">Dimasak</p>
                        <h3 id="stat-process" class="text-3xl font-black text-orange-500">0</h3>
                    </div>
                    <div class="bg-white p-6 rounded-[2rem] shadow-sm">
                        <p class="text-[10px] font-black text-stone-400 uppercase tracking-widest mb-1">Selesai</p>
                        <h3 id="stat-done" class="text-3xl font-black text-green-600">0</h3>
                    </div>
                    <div class="bg-white p-6 rounded-[2rem] shadow-sm border-2 border-orange-500">
                        <p class="text-[10px] font-black text-orange-400 uppercase tracking-widest mb-1">Total Order</p>
                        <h3 id="stat-total" class="text-3xl font-black">0</h3>
                    </div>
                </div>

                <div class="bg-white rounded-[2rem] shadow-sm overflow-hidden border border-stone-100">
                    <div class="p-6 border-b border-stone-50 flex justify-between items-center">
                        <h3 class="font-bold">Antrean Pesanan Aktif</h3>
                        <span class="text-[10px] bg-green-100 text-green-700 px-3 py-1 rounded-full font-bold">Auto Refresh On</span>
                    </div>
                    <table class="w-full text-left">
                        <thead class="bg-stone-50 text-[10px] font-black text-stone-400 uppercase">
                            <tr>
                                <th class="p-5">ID / Meja</th>
                                <th class="p-5">Item</th>
                                <th class="p-5">Total</th>
                                <th class="p-5">Status</th>
                                <th class="p-5 text-right">Aksi</th>
                            </tr>
                        </thead>
                        <tbody id="admin-order-body" class="divide-y divide-stone-50"></tbody>
                    </table>
                </div>
            </main>
        </div>
    </div>

    <div id="qris-modal" class="hidden fixed inset-0 bg-stone-950/95 backdrop-blur-xl z-[150] flex items-center justify-center p-6">
        <div class="bg-white rounded-[3rem] p-10 max-w-sm w-full text-center shadow-2xl">
            <h3 class="text-xl font-bold mb-6 italic tracking-tighter">KOPI SENJA QRIS</h3>
            <img src="https://api.qrserver.com/v1/create-qr-code/?size=250x250&data=KopiSenja-Sim-POS" class="w-56 h-56 mx-auto rounded-3xl mb-8 shadow-lg">
            <button onclick="finishOrder()" class="w-full bg-orange-600 text-white py-4 rounded-2xl font-bold uppercase tracking-widest text-xs">Saya Sudah Bayar</button>
        </div>
    </div>

    <script>
        // Database & State
        const menuData = [
            { id: 1, name: 'Cloudy Latte', price: 28000, img: '☁️', stock: 15, cat: 'Coffee' },
            { id: 2, name: 'Espresso Black', price: 18000, img: '☕', stock: 20, cat: 'Coffee' },
            { id: 3, name: 'Matcha Blossom', price: 32000, img: '🌸', stock: 5, cat: 'Non-Coffee' },
            { id: 4, name: 'Truffle Croissant', price: 45000, img: '🥐', stock: 10, cat: 'Food' },
            { id: 5, name: 'Salted Caramel', price: 30000, img: '🍯', stock: 12, cat: 'Coffee' }
        ];

        let cart = [];
        let orders = JSON.parse(localStorage.getItem('pos_orders')) || [];
        let currentPayment = 'Cash';

        function init() {
            renderMenu();
            updateCartUI();
        }

        function switchTab(id) {
            document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
            document.getElementById(id).classList.add('active');
            if(id === 'admin') renderAdmin();
        }

        function renderMenu() {
            const grid = document.getElementById('menu-grid');
            grid.innerHTML = menuData.map(p => `
                <div class="bg-white p-5 rounded-[2rem] border border-stone-100 shadow-sm hover:shadow-xl transition-all duration-500 group">
                    <div class="text-4xl mb-4 transform group-hover:scale-125 transition-transform duration-500">${p.img}</div>
                    <span class="text-[9px] font-black uppercase text-stone-300 tracking-[0.2em] mb-1 block">${p.cat}</span>
                    <h4 class="font-bold text-sm mb-1">${p.name}</h4>
                    <p class="text-orange-600 font-black text-sm mb-4 font-mono italic">Rp ${p.price.toLocaleString('id-ID')}</p>
                    <div class="flex items-center justify-between gap-2">
                        <span class="text-[9px] font-bold ${p.stock <= 5 ? 'text-red-500' : 'text-stone-400'} uppercase italic">Stok: ${p.stock}</span>
                        <button onclick="addToCart(${p.id})" ${p.stock === 0 ? 'disabled' : ''} class="bg-stone-50 text-stone-900 px-4 py-2 rounded-xl text-[10px] font-bold uppercase tracking-widest hover:bg-stone-950 hover:text-white transition-all disabled:opacity-30">Pesan</button>
                    </div>
                </div>
            `).join('');
        }

        function addToCart(id) {
            const p = menuData.find(x => x.id === id);
            const exists = cart.find(x => x.id === id);
            if(exists) exists.qty++; else cart.push({...p, qty: 1});
            updateCartUI();
        }

        function updateCartUI() {
            const list = document.getElementById('cart-items');
            document.getElementById('cart-count').innerText = cart.reduce((a,b) => a+b.qty, 0);
            
            list.innerHTML = cart.length === 0 ? `<div class="text-center py-10 opacity-20 italic text-xs">Kosong...</div>` :
                cart.map((item, idx) => `
                    <div class="flex justify-between items-center bg-stone-50 p-4 rounded-2xl border border-dashed border-stone-200">
                        <div><h5 class="text-xs font-bold">${item.name}</h5><p class="text-[9px] font-black text-orange-500 uppercase italic">x${item.qty}</p></div>
                        <div class="flex items-center gap-3">
                            <button onclick="changeQty(${idx}, -1)" class="w-6 h-6 rounded-full bg-white shadow-sm border border-stone-100 flex items-center justify-center text-xs">-</button>
                            <button onclick="changeQty(${idx}, 1)" class="w-6 h-6 rounded-full bg-white shadow-sm border border-stone-100 flex items-center justify-center text-xs">+</button>
                        </div>
                    </div>
                `).join('');

            const total = cart.reduce((a,b) => a + (b.price * b.qty), 0);
            document.getElementById('subtotal').innerText = `Rp ${total.toLocaleString('id-ID')}`;
            document.getElementById('grand-total').innerText = `Rp ${total.toLocaleString('id-ID')}`;
        }

        function changeQty(idx, delta) {
            cart[idx].qty += delta;
            if(cart[idx].qty < 1) cart.splice(idx, 1);
            updateCartUI();
        }

        function setPayment(method) {
            currentPayment = method;
            document.getElementById('pay-cash').classList.toggle('border-orange-500', method === 'Cash');
            document.getElementById('pay-cash').classList.toggle('bg-orange-50', method === 'Cash');
            document.getElementById('pay-qris').classList.toggle('border-orange-500', method === 'QRIS');
            document.getElementById('pay-qris').classList.toggle('bg-orange-50', method === 'QRIS');
        }

        function processOrder() {
            if(cart.length === 0) return alert('Pilih menu dulu!');
            if(currentPayment === 'QRIS') {
                document.getElementById('qris-modal').classList.remove('hidden');
            } else {
                finishOrder();
            }
        }

        function finishOrder() {
            const newOrder = {
                id: Math.floor(1000 + Math.random() * 9000),
                table: document.getElementById('table-select').value,
                items: [...cart],
                total: cart.reduce((a,b) => a + (b.price * b.qty), 0),
                method: currentPayment,
                status: 'Pending',
                time: new Date().toLocaleTimeString('id-ID', {hour:'2-digit', minute:'2-digit'})
            };

            // Update Stok
            cart.forEach(item => {
                const target = menuData.find(m => m.id === item.id);
                if(target) target.stock -= item.qty;
            });

            orders.unshift(newOrder);
            localStorage.setItem('pos_orders', JSON.stringify(orders));
            
            document.getElementById('qris-modal').classList.add('hidden');
            cart = [];
            updateCartUI();
            renderMenu();
            alert('Pesanan Terkirim! Mohon tunggu di meja Anda.');
        }

        // --- ADMIN FUNCTIONS ---
        function renderAdmin() {
            const body = document.getElementById('admin-order-body');
            body.innerHTML = orders.map((o, idx) => `
                <tr class="hover:bg-stone-50 transition text-[11px] font-bold">
                    <td class="p-5 font-mono text-stone-400">#${o.id}<br><span class="text-orange-500">MEJA ${o.table}</span></td>
                    <td class="p-5 text-stone-600">${o.items.map(i => `${i.name}(${i.qty})`).join(', ')}</td>
                    <td class="p-5 text-stone-950 italic">Rp ${o.total.toLocaleString('id-ID')}</td>
                    <td class="p-5">
                        <span class="px-3 py-1 rounded-full text-[8px] font-black uppercase tracking-tighter shadow-sm
                        ${o.status === 'Pending' ? 'bg-yellow-100 text-yellow-600' : o.status === 'Proses' ? 'bg-orange-500 text-white' : 'bg-green-100 text-green-600'}">
                            ${o.status}
                        </span>
                    </td>
                    <td class="p-5 text-right flex gap-1 justify-end">
                        ${o.status === 'Pending' ? `<button onclick="updateStatus(${idx}, 'Proses')" class="bg-stone-900 text-white p-2 rounded-lg text-[8px]">PROSES</button>` : ''}
                        ${o.status === 'Proses' ? `<button onclick="updateStatus(${idx}, 'Selesai')" class="bg-green-500 text-white p-2 rounded-lg text-[8px]">DONE</button>` : ''}
                        ${o.status === 'Selesai' ? `<span class="text-stone-300 uppercase italic">Archived</span>` : ''}
                    </td>
                </tr>
            `).join('');

            updateStats();
        }

        function updateStatus(idx, status) {
            orders[idx].status = status;
            localStorage.setItem('pos_orders', JSON.stringify(orders));
            renderAdmin();
        }

        function updateStats() {
            document.getElementById('stat-pending').innerText = orders.filter(o => o.status === 'Pending').length;
            document.getElementById('stat-process').innerText = orders.filter(o => o.status === 'Proses').length;
            document.getElementById('stat-done').innerText = orders.filter(o => o.status === 'Selesai').length;
            document.getElementById('stat-total').innerText = orders.length;
            
            const revenue = orders.filter(o => o.status === 'Selesai').reduce((a,b) => a + b.total, 0);
            document.getElementById('admin-revenue').innerText = `Rp ${revenue.toLocaleString('id-ID')}`;
        }

        function filterMenu() {
            const input = document.getElementById('search-input').value.toLowerCase();
            const grid = document.getElementById('menu-grid');
            const filtered = menuData.filter(m => m.name.toLowerCase().includes(input));
            // Re-render filtered (Logic serupa dengan renderMenu tapi ke filtered)
        }

        init();
    </script>
</body>
</html>
